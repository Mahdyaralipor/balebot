{
    "name": "balebot/balebot",
    "description": "The most complete PHP SDK for Bale Messenger bots. Supports Laravel out of the box.",
    "type": "library",
    "license": "MIT",
    "keywords": ["bale", "bale-messenger", "balebot", "bot", "sdk", "laravel", "php", "telegram-like"],
    "homepage": "https://github.com/balebot/balebot",
    "readme": "README.md",
    "authors": [
        {
            "name": "Mahdyar Alipor",
            "email": "mahdyaralipor0@gmail.com",
            "homepage": "https://github.com/Mahdyaralipor",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Use Guzzle as HTTP client instead of native cURL (^7.0)",
        "illuminate/support": "Required for Laravel integration (^10.0|^11.0)"
    },
    "autoload": {
        "psr-4": {
            "BaleBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BaleBot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BaleBot\\Laravel\\BaleServiceProvider"
            ],
            "aliases": {
                "Bale": "BaleBot\\Laravel\\Facades\\Bale"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
